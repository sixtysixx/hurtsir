<!DOCTYPE html>
<html lang="en" style="scroll-behavior:smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title or "SirHurt Troubleshooting Guide" }}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen, sans-serif;
      line-height: 1.75;
      color: #e0e0e0;
      background: #0d1117;
      padding: 2rem 1rem;
    }
    .container {
      max-width: 820px;
      margin: 0 auto;
      background: #161b22;
      border-radius: 12px;
      padding: 2.5rem;
      box-shadow: 0 4px 24px rgba(0,0,0,.4);
    }
    h1 { font-size: 1.75rem; margin-bottom: 1rem; color: #f0f0f0; }
    h2 { font-size: 1.3rem; margin: 2rem 0 .75rem; padding-bottom: .5rem; border-bottom: 2px solid #21262d; color: #f0f0f0; }
    h3 { font-size: 1.1rem; margin: 1.5rem 0 .5rem; color: #f0f0f0; }
    h4 { font-size: 1rem; margin: 1.25rem 0 .5rem; color: #f0f0f0; }
    p { margin-bottom: 1rem; }
    ul, ol { margin: 0 0 1rem 1.5rem; }
    li { margin-bottom: .4rem; }
    a { color: #58a6ff; text-decoration: none; }
    a:hover { text-decoration: underline; color: #79c0ff; }
    code {
      background: #21262d;
      padding: .15em .4em;
      border-radius: 4px;
      font-size: .9em;
      color: #f0f0f0;
    }
    pre {
      background: #0d1117;
      color: #c9d1d9;
      padding: 1rem;
      border-radius: 8px;
      overflow-x: auto;
      margin-bottom: 1rem;
      font-size: .9rem;
      border: 1px solid #21262d;
      position: relative;
    }
    pre code { background: none; padding: 0; border-radius: 0; color: inherit; }
    .copy-btn {
      position: absolute; top: 8px; right: 8px;
      background: #21262d; color: #8b949e; border: 1px solid #30363d;
      border-radius: 6px; padding: 4px 10px; font-size: .75rem;
      cursor: pointer; opacity: 0; transition: opacity .2s, color .2s;
    }
    pre:hover .copy-btn { opacity: 1; }
    .copy-btn:hover { color: #f0f0f0; background: #30363d; }
    .copy-btn.copied { color: #3fb950; border-color: #3fb950; }
    hr { border: none; border-top: 1px solid #21262d; margin: 2rem 0; }
    blockquote {
      border-left: 4px solid #30363d;
      padding: .75rem 1rem;
      margin-bottom: 1rem;
      background: #0d1117;
      border-radius: 0 6px 6px 0;
      color: #8b949e;
    }
    strong { font-weight: 600; color: #f0f0f0; }
    .embed {
      background: #0d1117;
      border: 1px solid #21262d;
      border-left: 4px solid #e0e0e0;
      border-radius: 8px;
      padding: 1.25rem 1.5rem;
      margin-bottom: 1.25rem;
      opacity: 0;
      transform: translateY(20px);
      transition: opacity .5s ease, transform .5s ease, border-color .3s;
    }
    .embed.visible { opacity: 1; transform: translateY(0); }
    .embed:hover { border-color: #e0e0e0; }
    .embed h3 { margin-top: 0; }
    video { border-radius: 8px; margin-top: .5rem; }
    @media (max-width: 600px) {
      body { padding: 1rem .5rem; }
      .container { padding: 1.5rem; }
    }
  </style>
</head>
<body>
  <div class="container">
    {{ content | safe }}
  </div>
  <script>
    const observer = new IntersectionObserver(entries => {
      entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold: .1 });
    document.querySelectorAll('.embed').forEach(el => observer.observe(el));
    document.querySelectorAll('pre').forEach(pre => {
      const btn = document.createElement('button');
      btn.className = 'copy-btn'; btn.textContent = 'Copy';
      btn.onclick = async () => {
        if (pre.dataset.copy) return navigator.clipboard.writeText(pre.dataset.copy);
        const clone = pre.cloneNode(true);
        clone.querySelector('.copy-btn')?.remove();
        await navigator.clipboard.writeText(clone.textContent.trim());
        btn.textContent = 'Copied!'; btn.classList.add('copied');
        setTimeout(() => { btn.textContent = 'Copy'; btn.classList.remove('copied'); }, 2000);
      };
      pre.appendChild(btn);
    });
  </script>
</body>
</html>
